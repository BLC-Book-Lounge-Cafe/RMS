generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma-rms/client"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  pending
  confirmed
  cancelled
}

model book_reservation {
  id          Int      @id @default(autoincrement())
  book_id     Int
  name        String   @db.VarChar(255)
  reserved_at DateTime @db.Date
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([book_id, reserved_at])
  @@index([book_id])
}

model table_reservation {
  id         Int      @id @default(autoincrement())
  table_id   Int
  name       String   @db.VarChar(255)
  phone      String   @db.VarChar(20)
  start_at   DateTime
  end_at     DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([table_id])
  @@index([start_at, end_at])
}

model quick_reservation {
  id    Int               @id @default(autoincrement())
  name  String            @db.VarChar(255)
  phone String            @db.VarChar(20)
  status       ReservationStatus @default(pending)
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  @@index([status])
  @@index([created_at])
}
